{% extends "template.njk" %}

{% block content %}
  <a href="/tasks" class="govuk-back-link">Back to tasks</a>

  <h1 class="govuk-heading-xl">{{ task.title }}</h1>

  <dl class="govuk-summary-list">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Description</dt>
      <dd class="govuk-summary-list__value">{{ task.description or "None" }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Status</dt>
      <dd class="govuk-summary-list__value">{{ task.status }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Due date/time</dt>
      <dd class="govuk-summary-list__value">{{ task.dueDateTime }}</dd>
    </div>
  </dl>

  <form method="post" action="/tasks/{{ task.id }}/status">
    <div class="govuk-form-group">
      <label class="govuk-label" for="status">Update status</label>
      <select class="govuk-select" id="status" name="status">
        {% for status in statuses %}
          <option value="{{ status }}" {% if task.status == status %}selected{% endif %}>{{ status }}</option>
        {% endfor %}
      </select>
    </div>
    <button class="govuk-button" data-module="govuk-button" type="submit">Update status</button>
  </form>

  <form method="post" action="/tasks/{{ task.id }}/delete">
    <button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">Delete task</button>
  </form>
{% endblock %}
