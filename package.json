{
  "name": "hmcts-dev-test-frontend",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production ts-node -r tsconfig-paths/register src/main/server.ts",
    "start:dev": "nodemon --config nodemon.json",
    "lint": "stylelint **/*.scss -q && eslint . && prettier --check .",
    "lint:fix": "prettier --write . .github && eslint --fix .",
    "build": "yarn webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production yarn webpack --mode production --config webpack.config.js",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:functional": "NODE_TLS_REJECT_UNAUTHORIZED=0 codeceptjs run --steps",
    "cichecks": "yarn install && yarn build && yarn rebuild puppeteer && yarn lint && yarn test && yarn test:routes",
    "prepare": "husky install"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/nunjucks": "^3.2.6",
    "@types/serve-favicon": "^2.5.7",
    "axios": "^1.18.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "govuk-frontend": "^6.3.0",
    "nunjucks": "^3.2.4",
    "postcss": "^8.5.16",
    "serve-favicon": "^2.5.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@codeceptjs/allure-legacy": "^1.0.2",
    "@codeceptjs/configure": "^1.0.6",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/parser": "^8.62.1",
    "codeceptjs": "^4.0.8",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-util": "^30.4.1",
    "lint-staged": "^17.0.8",
    "mini-css-extract-plugin": "^2.10.2",
    "nodemon": "^3.1.14",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-dev-middleware": "^8.0.3"
  },
  "dependenciesMeta": {
    "govuk-frontend": {
      "unplugged": true
    }
  },
  "resolutions": {
    "@types/express": "^5.0.6",
    "semver": "^7.5.2",
    "axios": ">1.6.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md,html,json}": "prettier --write"
  },
  "packageManager": "yarn@4.16.0"
}
